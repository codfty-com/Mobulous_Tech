{
  "info": {
    "name": "Mobulous Tech API",
    "_postman_id": "mobulous-tech-api-collection-v1",
    "description": "Complete API collection for Mobulous Tech backend. Deployed on Vercel.\n\n**Setup:**\n1. Import this file into Postman\n2. Create an Environment with variable `baseUrl` = your deployment URL\n3. For local dev: `baseUrl` = `http://localhost:3000`\n4. For production: `baseUrl` = `https://<your-vercel-domain>.vercel.app`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Change to your Vercel URL for production testing"
    },
    {
      "key": "userEmail",
      "value": "testuser@example.com",
      "type": "string"
    },
    {
      "key": "userPassword",
      "value": "Password123",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "Auto-populated after login"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "MongoDB _id. Set from Create User/Login/Get All Users response for profile testing"
    },
    {
      "key": "otpCode",
      "value": "",
      "type": "string",
      "description": "Manually paste OTP received on email"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Simple liveness probe. Returns 200 with a text message if the server is running."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('API is running', () => pm.expect(pm.response.text()).to.include('running'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Signup",
      "item": [
        {
          "name": "1. Create User (Signup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/create-user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "create-user"]
            },
            "description": "Register a new user. Sends a 6-digit OTP to the provided email. Phone is optional."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Success or conflict', () => {",
                  "  pm.expect([200, 201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (json.data && json.data.userId) {",
                  "  pm.collectionVariables.set('userId', json.data.userId);",
                  "  console.log('userId saved:', json.data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Verify Email OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"otp\": \"{{otpCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/verify-email-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "verify-email-otp"]
            },
            "description": "Paste the OTP received on email into the `otpCode` collection variable, then send this request."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Success true', () => pm.expect(json.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Login",
      "item": [
        {
          "name": "Login with Email & Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login-user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login-user"]
            },
            "description": "Login with email and password. NOTE: JWT token is not yet returned by the server (known issue). Token variable will be set if/when the server adds it."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Login success', () => pm.expect(json.success).to.be.true);",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "  console.log('Token saved to authToken variable');",
                  "}",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('userId', json.data._id);",
                  "  console.log('userId saved:', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login with Google (ID Token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"PASTE_GOOGLE_ID_TOKEN_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login-google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login-google"]
            },
            "description": "Login or register via Google. Obtain an ID token from Google Sign-In SDK on your frontend/mobile app."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Success true', () => pm.expect(json.success).to.be.true);",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "}",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('userId', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
